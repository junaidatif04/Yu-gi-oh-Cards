rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function: Check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'junaidatif40@gmail.com';
    }

    // Users collection: Store user profile/settings
    // - Users can read/write their OWN data
    // - Admin can read ALL user data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
      
      // User's private decks subcollection
      match /decks/{deckId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
      }

      // User's chat sessions subcollection
      match /chat_sessions/{sessionId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
      }
    }

    // Analytics Logs: Only admin can read
    match /analytics_logs/{logId} {
      allow read: if isAdmin();
    }

    // Chat feedback collection: Store AI chat ratings
    // - Any logged-in user can create feedback
    // - Only admin can read all feedback
    match /chat_feedback/{docId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    // Shared decks collection: Public deck links
    // - Any logged-in user can create a shared deck
    // - ANYONE can read shared decks (public links)
    // - Owner or admin can delete
    // - Authenticated users can update (for voting)
    match /sharedDecks/{deckId} {
      allow create: if request.auth != null;
      allow update: if request.auth != null; // Needed for incrementing vote counts
      allow read: if true;
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.ownerId || isAdmin());

      // Votes subcollection: access control for voting
      match /votes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}